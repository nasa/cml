/*****************************************************************************
Vehicle sim object
*****************************************************************************/

##include "jeod/models/dynamics/dyn_body/include/dyn_body.hh"
##include "jeod/models/dynamics/body_action/include/mass_body_init.hh"
##include "jeod/models/dynamics/body_action/include/body_attach_matrix.hh"
##include "jeod/models/utils/math/include/vector3.hh"
##include "jeod/models/utils/math/include/matrix3x3.hh"
##include "cml/models/dynamics/state_initialize/state_initialize/include/state_initialize.hh"

##include "../../include/dynamic_mass_body.hh"
##include "../../include/dynamic_mass_group.hh"
##include "../../include/dynamic_mass_string.hh"

class VehicleSimObject : public Trick::SimObject {
 protected:
  jeod::DynManager & dyn_manager;
 public:
  jeod::DynBody        body;
  StateInitialize      state_initialize;
  jeod::MassProperties nominal_override;
  jeod::MassBodyInit   mass_init[4]; // (--)  0 is tank[0]
                                     //       1 is body
                                     //       2 is tank[1]
                                     //       3 is free_flying_body
  jeod::BodyAttachMatrix tank_attach[2];

  // Instances for testing
  DynamicMassBody         tanks[2];
  DynamicMassBody         free_flying_body;
  DynamicMassGroup        group;
  DynamicMassGroup        group_alt;

  VehicleSimObject(jeod::DynManager & dyn_mgr_in)
    :
    dyn_manager (dyn_mgr_in)
  {
    // set up tests
    ("default_data")  configure_system();
    // support job:
    P_ENV ("initialization")  body.initialize_model( dyn_manager);

    // Jobs for testing
    P_BODY ("initialization")   group.initialize();
    (1.0, 1.0, "environment")   move_mass();
    (1.0, "scheduled")          group.update_group_mass();
  };
 

  //**************************************************************************
  // test_set_initial_position
  // Purpose:(tests the set_initial_position method, which cannot be called
  //          directly from the input file with a NULL argument, so this
  //          provides the interface to test NULL.)
  //**************************************************************************
  void test_set_initial_position( double * new_pos)
  {
    tanks[0].set_initial_position( true, new_pos);
  }

  //**************************************************************************
  // test_set_CM_offset
  // Purpose:(tests the set_CM_offset method)
  //**************************************************************************
  void test_set_CM_offset( double *offset)
  {
    tanks[0].set_CM_offset(offset);
  }
 
  //**************************************************************************
  // add_mass_data
  // Purpose:(adds mass-data to test incomplete interpolation configuration.
  //          this dummy mass-array will be used only for error checking)
  //**************************************************************************
  void add_mass_data()
  {
    static const double mass_array[2] = {1000.0, 0.0};
    tanks[0].dynamic_properties.interpolation.mass_indep.load_data(mass_array, 2);
  }

 private:
  VehicleSimObject( const VehicleSimObject&);
  VehicleSimObject & operator= ( const VehicleSimObject&);

  void configure_system()
  {
    group.name = "dyn_mass_group_test";

    for (int ii = 0; ii < 4; ii++) {
      mass_init[ii].properties.mass = 10.0;
      mass_init[ii].properties.position[0] = ii -1;
      mass_init[ii].properties.position[1] = 0;
      mass_init[ii].properties.position[2] = 0;
      jeod::Matrix3x3::identity( mass_init[ii].properties.inertia);

      mass_init[ii].properties.pt_orientation.data_source =
                                      jeod::Orientation::InputEigenRotation;
      jeod::Vector3::unit(0, mass_init[ii].properties.pt_orientation.eigen_axis);
      mass_init[ii].properties.pt_orientation.eigen_angle = M_PI_2;
      dyn_manager.add_body_action( mass_init[ii] );
    }

    nominal_override.mass = 12.0;
    nominal_override.position[0] = -1.5;
    nominal_override.position[1] = 0;
    nominal_override.position[2] = 0;
    nominal_override.inertia[0][0] = 1.1;

    mass_init[0].set_subject_body(tanks[0]);
    mass_init[1].set_subject_body(body);
    mass_init[2].set_subject_body(tanks[1]);
    mass_init[3].set_subject_body(free_flying_body);
    for (unsigned int ii = 0; ii < 2; ii++) {
      group.add_mass_to_group( &tanks[ii]);
      tank_attach[ii].set_subject_body(tanks[ii]);
      tank_attach[ii].set_parent_body(body);
      jeod::Vector3::initialize(tank_attach[ii].offset_pstr_cstr_pstr);
      tank_attach[ii].pstr_cstr.data_source = jeod::Orientation::InputMatrix;
      jeod::Matrix3x3::identity( tank_attach[ii].pstr_cstr.trans);
      dyn_manager.add_body_action( tank_attach[ii] );
    }
  };

  void move_mass()
  {
    if (group.is_active()) {
      // Note - mass_consumed_step should always be incremented (or
      //        decremented), never assigned from outside the model.
      // This is handled inside this if-statement to allow testing of
      // activating the dynamic-mass mid-run.  Without the "if-block"
      // protection, mass consumption would start incrementing at the start of
      // the sim and be applied in one go when the model activates.  This way,
      // the mass depletion does not start until the model gets activated.
      tanks[0].dynamic_properties.mass_consumed_step += 1.0;
      tanks[1].dynamic_properties.mass_consumed_step -= 1.0;
    }
  };
};
VehicleSimObject vehicle(dynamics.dyn_manager);

IntegLoop sim_integ_loop (DYNAMICS) dynamics;
