/*******************************************************************************
mass body disp sim object
This sim object provides 3 mass bodies, attached in sequence, starting with
index 0 as the root.

The main apply method is not called from the S_define, instead it is called
out of the input files to facilitate testing different combinations of
target-body and adjustable-body specifications.
*******************************************************************************/

##include "jeod/models/dynamics/mass/include/mass.hh"
##include "jeod/models/dynamics/body_action/include/mass_body_init.hh"
##include "jeod/models/dynamics/body_action/include/body_attach_matrix.hh"
##include "../../include/mass_body_composite_dispersions.hh"

class MassBodyDispSimObject : public Trick::SimObject {
public:
  jeod::MassBody                body[4];
  jeod::MassBodyInit            mass_init[3];
  jeod::BodyAttachMatrix        attach[2];

  MassBodyCompositeDispersions  adjust_0;
  MassBodyCompositeDispersions  adjust_1;

  MassBodyDispSimObject()
    :
    adjust_0( body[0]),
    adjust_1( body[1])
  { };

private:
  MassBodyDispSimObject( const MassBodyDispSimObject&);
  MassBodyDispSimObject & operator = ( const MassBodyDispSimObject&);
};
MassBodyDispSimObject so;
