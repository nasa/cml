##include "jeod/models/dynamics/dyn_body/include/dyn_body.hh"
##include "jeod/models/dynamics/body_action/include/mass_body_init.hh"
##include "cml/models/dynamics/state_initialize/state_initialize/include/state_initialize.hh"
##include "cml/models/environment/gravity/fast_gravity/include/spherical_harmonics_fast_gravity_controls.hh"

##include "../../include/scalar_integrable_object.hh"

class ScalarIntegSimObject : public Trick::SimObject {
  public:
   jeod::DynBody                         body;
   jeod::MassBodyInit                    mass_init;
   StateInitialize                       state_initialize;
   SphericalHarmonicsFastGravityControls grav_controls_earth;
   double                                angle;
   double                                angle_rate;
   ScalarIntegrableObject                angle_integrable_object;

  ScalarIntegSimObject(jeod::DynManager & dyn_mgr_in)
    :
    angle(60.0),
    angle_rate(15.0),
    angle_integrable_object(angle, angle_rate),
    dyn_manager (dyn_mgr_in)
  {
          ("default_data")      body.add_integrable_object(
                                       angle_integrable_object);
    P_ENV ("initialization")      body.initialize_model( dyn_manager);
  }; 
  private:
    ScalarIntegSimObject( const ScalarIntegSimObject&);
    ScalarIntegSimObject & operator = ( const ScalarIntegSimObject&);

  protected:
    jeod::DynManager & dyn_manager;

};
ScalarIntegSimObject scalar_integ(dynamics.dyn_manager);


IntegLoop sim_integ_loop (DYNAMICS) dynamics;
