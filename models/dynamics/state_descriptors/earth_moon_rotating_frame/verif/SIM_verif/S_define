/*****************************************************************************
AntaresUnitTestSimObject
Purpose:(The sim)
*****************************************************************************/

// Include headers for classes that this class contains:
##include "cml/models/tools/unit_test/models/include/unit_test.hh"
##include "../../include/earth_moon_rotating_frame.hh"

class AntaresUnitTestSimObject: public Trick::SimObject {
 private:
   jeod::DynManager    & dyn_manager;
   jeod::RefFrameState & earth_inrtl;
   jeod::RefFrameState & moon_inrtl;
 public:
  // Framework
  UnitTestFramework framework;
  // Model for testing:
  EarthMoonRotatingFrame  em_rotating_frame;
  // support variables
  double earth_moon_mass_ratio; // (--) also used as a flag

  AntaresUnitTestSimObject( jeod::DynManager    & dyn_manager_in,
                            jeod::RefFrameState & earth_inrtl_in,
                            jeod::RefFrameState & moon_inrtl_in)
    :
    dyn_manager (dyn_manager_in),
    earth_inrtl(earth_inrtl_in),
    moon_inrtl(moon_inrtl_in),
    em_rotating_frame( dyn_manager),
    earth_moon_mass_ratio(-1.0)
  {
    // Framework
    ("initialization")   framework.initialize();
    (1.0, "environment") framework.update();
    // test-specific jobs:
    ("initialization") em_rotating_frame.initialize();
    (1.0, "environment") update_planet_state();
    (1.0, "environment") em_rotating_frame.update();
   }

  void update_planet_state() {
    if (earth_moon_mass_ratio <= 0.0) return;
    moon_inrtl.trans.position[0] = -earth_inrtl.trans.position[0] * earth_moon_mass_ratio;
    moon_inrtl.trans.position[1] = -earth_inrtl.trans.position[1] * earth_moon_mass_ratio;
    moon_inrtl.trans.position[2] = -earth_inrtl.trans.position[2] * earth_moon_mass_ratio;
    moon_inrtl.trans.velocity[0] = -earth_inrtl.trans.velocity[0] * earth_moon_mass_ratio;
    moon_inrtl.trans.velocity[1] = -earth_inrtl.trans.velocity[1] * earth_moon_mass_ratio;
    moon_inrtl.trans.velocity[2] = -earth_inrtl.trans.velocity[2] * earth_moon_mass_ratio;
  }

 private:
  AntaresUnitTestSimObject (const AntaresUnitTestSimObject&);
  AntaresUnitTestSimObject & operator = (const AntaresUnitTestSimObject&);
};
AntaresUnitTestSimObject test(dynamics.dyn_manager,
                              earth.planet.inertial.state,
                              moon.planet.inertial.state);

