  /*****************************************************************************
  Purpose: (Testing "log_protected" function for both doubles and floats.)
  *****************************************************************************/
  void log_protected_testing() {
    // This section tests the double capabilities of log_protected.
    log_protected_vals_double[0] = MathUtils::log_protected( (double)  1.0);
    compare( MathUtils::is_near_equal( log_protected_vals_double[0],
                                       (double) 0.0),
             true,
             "log_protected(double 1.0) is_near_equal 0.0");

    log_protected_vals_double[1] = MathUtils::log_protected(std::exp((double) 1.0));
    compare( MathUtils::is_near_equal( log_protected_vals_double[1],
                                       (double) 1.0),
             true,
             "log_protected(double e) is equal to 1.0");

    log_protected_vals_double[2] = MathUtils::log_protected( (double)  1.e-308);
    compare( MathUtils::is_near_equal( (double) log_protected_vals_double[2],
                                       (double) -709.1962086421661),
             true,
             "log_protected(double 1e-308) is_near_equal -709.196");

    log_protected_vals_double[3] = MathUtils::log_protected( (double)  1.e308);
    compare( MathUtils::is_near_equal( (double) log_protected_vals_double[3],
                                       (double) 709.1962086421661),
             true,
             "log_protected(double 1e308) is_near_equal 709.196");

    // This next section tests the float capabilities of log_protected.
    log_protected_vals_float[0] = MathUtils::log_protected( (float)  1.0);
    compare( MathUtils::is_near_equal( log_protected_vals_float[0],
                                       (float) 0.0),
             true,
             "log_protected(float 1.0) is_near_equal 0.0");

    // NOTE -- extra (float) necessary in here. For some reason,
    // exp((float)1.0) is returning a double on some builds and branching to
    // test the function using a double parameter instead of a float parameter.
    log_protected_vals_float[1] = MathUtils::log_protected((float) std::exp((float) 1.0));
    compare( MathUtils::is_near_equal( log_protected_vals_float[1],
                                       (float)  1.0,
                                       1),
             true,
             "log_protected(float e) is equal to 1.0 to within 1 ULP");

    // NOTE -- the success criteria for this comparison has shifted between 1.0 and
    // 0.99999994 on successive compiler upgrades.
    compare( MathUtils::is_near_equal( log_protected_vals_float[1],
                                       (float)  0.99999994),
             true,
             "log_protected(float e) is equal to 0.99999994");

    log_protected_vals_float[2] = MathUtils::log_protected( (float)  1.e-38);
    compare( MathUtils::is_near_equal( log_protected_vals_float[2],
                                       (float) -87.49823),
             true,
             "log_protected(float 1e-38) is_near_equal -87.49823");

    log_protected_vals_float[3] = MathUtils::log_protected( (float)  1.e38);
    compare( MathUtils::is_near_equal( log_protected_vals_float[3],
                                       (float) 87.49823),
             true,
             "log_protected(float 1e38) is_near_equal 87.49823");

    check_comparison();
  }

