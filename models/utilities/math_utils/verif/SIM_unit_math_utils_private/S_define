  /*****************************************************************************
  Purpose:(Testing "div_protected" function using both doubles and floats.)
  *****************************************************************************/
  void div_protected_testing() {
    // This section tests the double capabilities of divide_protected.
    div_protected_vals_double[0] = MathUtils::divide_protected( (double) 15.0,
                                                                (double)  5.0);
    compare( MathUtils::is_near_equal( (double) div_protected_vals_double[0],
                                       (double) 3.0),
             true,
             "divide_protected(double 15.0, double 5.0) is_near_equal 3.0");

    div_protected_vals_double[1] = MathUtils::divide_protected( (double)  1.0,
                                                                (double)  0.0,
                                                                (double) 70.0);
    compare( MathUtils::is_near_equal( (double) div_protected_vals_double[1],
                                       (double) 70.0),
             true,
             "divide_protected(double 1.0, double 0.0, 70.0) is_near_equal 70.0");

    div_protected_vals_double[2] = MathUtils::divide_protected( (double) 1.e-300,
                                                                (double) 1.e300,
                                                                (double) 2.0);
    compare( MathUtils::is_near_equal( (double) div_protected_vals_double[2],
                                       (double) 0.0),
             true,
             "divide_protected(double 1.e-300, double 1.e300) is_near_equal 0.0");

    div_protected_vals_double[3] = MathUtils::divide_protected( (double) 1.e38,
                                                                (double) 1.e-38,
                                                                (double) 35.0);
    compare( MathUtils::is_near_equal( (double) div_protected_vals_double[3],
                                       (double) 1e76),
             true,
             "divide_protected(double 1.e38, double 1.e-38, 35.0) is_near_equal 1e76");

    div_protected_vals_double[4] = MathUtils::divide_protected( (double) 1.e300,
                                                                (double) 1.e-300,
                                                                (double) 35.0);
    compare( MathUtils::is_near_equal( (double) div_protected_vals_double[4],
                                       (double) 35.0),
             true,
             "divide_protected(double 1.e300, double 1.e-300, 35.0) is_near_equal 35.0");
    // This next section tests the float capabilities of divide_protected.
    div_protected_vals_float[0] = MathUtils::divide_protected( (float) 15.0,
                                                               (float)  5.0);
    compare( MathUtils::is_near_equal( (float)  div_protected_vals_float[0],
                                       (float)  3.0),
             true,
             "divide_protected(float 15.0, float 5.0) is_near_equal 3.0");

    div_protected_vals_float[1] = MathUtils::divide_protected( (float)  1.0,
                                                               (float)  0.0,
                                                               (float)  3.14);
    compare( MathUtils::is_near_equal( (float)  div_protected_vals_float[1],
                                       (float)  3.14),
             true,
             "divide_protected(float 1.0, float 0.0, 3.14) is_near_equal 3.14");

    div_protected_vals_float[2] = MathUtils::divide_protected( (float) 1.e-38,
                                                               (float) 1.e38,
                                                               (float) 2.0);
    compare( MathUtils::is_near_equal( (float)  div_protected_vals_float[2],
                                       (float)  0.0),
             true,
             "divide_protected(float 1.e-38, float 1.e38) is_near_equal 0.0");

    div_protected_vals_float[3] = MathUtils::divide_protected( (float) 1.e38,
                                                               (float) 1.e-38,
                                                               (float) 5.45678);
    compare( MathUtils::is_near_equal( (float)  div_protected_vals_float[3],
                                       (float)  5.45678),
             true,
             "divide_protected(float 1.e38, float 1.e-38, 5.45678) is_near_equal 5.45678");

    check_comparison();
  }

