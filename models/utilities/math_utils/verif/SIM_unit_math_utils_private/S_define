  /*****************************************************************************
  Purpose:(Testing the "is_equal" function
  *****************************************************************************/
  void is_equal_testing() {
    is_equal_vals[0] = MathUtils::is_equal( (int) 3,
                                            (int) 3);
    compare( is_equal_vals[0],
             true,
             "int 3 is equal to int 3");
             
    is_equal_vals[1] = MathUtils::is_equal( (int) 3,
                                            (int) 4);
    compare( is_equal_vals[1],
             false,
             "int 3 is not equal to int 4");
             
    is_equal_vals[2] = MathUtils::is_equal( (bool) 1,
                                            (bool) 1);  
    compare( is_equal_vals[2],
             true,
             "bool 1 is equal to bool 1");
             
    is_equal_vals[3] = MathUtils::is_equal( (bool) 0,
                                            (bool) 1); 
    compare( is_equal_vals[3],
             false,
             "bool 0 is not equal to bool 1");
             
    is_equal_vals[4] = MathUtils::is_equal( (double) 3.45,
                                            (double) 3.45);  
    compare( is_equal_vals[4],
             true,
             "double 3.45 is equal to double 3.45");
             
    is_equal_vals[5] = MathUtils::is_equal( (double) 3.45,
