    compare( has_changed_from_vals[3],
             true,
             "float 3.45 has changed from float 4.56");

    has_changed_from_vals[4] = MathUtils::has_changed_from( (float) 4.56,
                                                                  (float) 3.45);
    compare( has_changed_from_vals[4],
             true,
             "float 4.56 has changed from float 3.45");

    has_changed_from_vals[5] = MathUtils::has_changed_from( (float) 3.45,
                                                                  (float) 3.45);
    compare( has_changed_from_vals[5],
             false,
             "float 3.45 has not changed from float 3.45");

