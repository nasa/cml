  /*****************************************************************************
  Purpose:(Testing the "is_near_equal" function for both doubles and floats.)
  *****************************************************************************/
  void is_near_equal_testing() {
    // This section tests the double capabilities of is_near_equal
    is_near_equal_vals[0] = MathUtils::is_near_equal( (double) 3.45,
                                                             (double) 3.45);
    compare( is_near_equal_vals[0],
             true,
             "double 3.45 == double 3.45, ulp=0.5");

    is_near_equal_vals[1] = MathUtils::is_near_equal( (double) 1.0000000000000001,
                                                             (double) 1.0);
    compare( is_near_equal_vals[1],
             true,
             "double 1.0000000000000001 == double 1.0, ulp=0.5");

    is_near_equal_vals[2] = MathUtils::is_near_equal( (double) 1.000000000000001,
                                                             (double) 1.0);
    compare( is_near_equal_vals[2],
             false,
             "double 1.000000000000001 == double 1.0, ulp=0.5");

    is_near_equal_vals[3] = MathUtils::is_near_equal( (double) 5.4321,
                                                             (double) 5.4322,
                                                             (double) 1.0);
    compare( is_near_equal_vals[3],
             false,
             "double 5.4321 == double 5.4322, ulp=1.0");

    is_near_equal_vals[4] = MathUtils::is_near_equal( (double) 5.4321,
                                                             (double) 5.4322,
                                                             (double) 1e7);
    compare( is_near_equal_vals[4],
             false,
             "double 5.4321 == double 5.4322, ulp=1e7");

    is_near_equal_vals[5] = MathUtils::is_near_equal( (double) 5.4321,
                                                             (double) 5.4322,
                                                             (double) 1e15);
    compare( is_near_equal_vals[5],
             true,
             "double 5.4321 == double 5.4322, ulp=1e15");

    // This next section tests the float capabilities of is_near_equal
    is_near_equal_vals[6] = MathUtils::is_near_equal( (float) 3.45,
                                                            (float) 3.45);
    compare( is_near_equal_vals[6],
             true,
             "float 3.45 == float 3.45");

    is_near_equal_vals[7] = MathUtils::is_near_equal( (float) 1.00000001,
                                                            (float) 1.0);
    compare( is_near_equal_vals[7],
             true,
             "float 1.00000001 == float 1.0");

    is_near_equal_vals[8] = MathUtils::is_near_equal( (float) 1.0000001,
                                                            (float) 1.0);
    compare( is_near_equal_vals[8],
             false,
             "float 1.0000001 == float 1.0");

    is_near_equal_vals[9] = MathUtils::is_near_equal( (float) 5.4321,
                                                            (float) 5.4322,
                                                            (float) 1.0);
    compare( is_near_equal_vals[9],
             false,
             "float 5.4321 == float 5.4322, ulp=1.0");

    is_near_equal_vals[10] = MathUtils::is_near_equal( (float) 5.4321,
                                                            (float) 5.4322,
                                                            (float) 1e7);
    compare( is_near_equal_vals[10],
             true,
             "float 5.4321 == float 5.4322, ulp=1e7");

    check_comparison();
  }

