  /*****************************************************************************
  Purpose:(Testing "QuadraticSolver::solve" function.)
  *****************************************************************************/
  void quadratic_solver_testing() {
    QuadraticSolver quadratic;
    bool success;

    // x^2-3x+2=0
    quadratic.a = 1, quadratic.b = -3, quadratic.c = 2;
    quadratic.solve();
    quadratic_solver_vals[0][0] = quadratic.root1, quadratic_solver_vals[0][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[0]),
                                       std::array<double, 2>{1.0, 2.0}),
             true,
             "Roots 1 and 2 of x^2-3x+2=0 are is_near_equal to 1.0 and 2.0, respectively");

             
    // x^2+2x+1=0
    QuadraticSolver quadratic2(1, 2, 1); // to add coverage over specialized constructor
    quadratic_solver_vals[1][0] = quadratic2.root1, quadratic_solver_vals[1][1] = quadratic2.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[1]),
                                       std::array<double, 2>{-1.0, -1.0}),
             true,
             "Roots 1 and 2 of x^2+2x+1=0 are both is_near_equal to -1.0");

    // 2x+1=0
    quadratic.a = 0, quadratic.b = 2, quadratic.c = 1;
    quadratic.solve();
    quadratic_solver_vals[2][0] = quadratic.root1, quadratic_solver_vals[2][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[2]),
                                       std::array<double, 2>{-0.5, -0.5}),
             true,
             "Roots 1 and 2 of 2x+1=0 are both is_near_equal to -0.5");

    // x^2-1=0
    quadratic.a = 1, quadratic.b = 0, quadratic.c = -1;
    quadratic.solve();
    quadratic_solver_vals[3][0] = quadratic.root1, quadratic_solver_vals[3][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[3]),
                                       std::array<double, 2>{-1.0, 1.0}),
             true,
             "Roots 1 and 2 of x^2-1=0 are is_near_equal to -1.0 and 1.0, respectively");

    // x^2+1=0
    quadratic.a = 1, quadratic.b = 0, quadratic.c = 1;
    success = quadratic.solve();
    compare( success,
             false,
             "Roots of x^2+1=0 are both imaginary, and are not computed");
    quadratic_solver_vals[4][0] = quadratic.root1, quadratic_solver_vals[4][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[4]),
                                       std::array<double, 2>{0.0, 0.0}),
             true,
             "Roots 1 and 2 of x^2+1=0 are both is_near_equal to 0.0");

    // x^2+3x=0
    quadratic.a = 1, quadratic.b = 3, quadratic.c = 0;
    quadratic.solve();
    quadratic_solver_vals[5][0] = quadratic.root1, quadratic_solver_vals[5][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[5]),
                                       std::array<double, 2>{0.0, -3.0}),
             true,
             "Roots 1 and 2 of x^2+3x=0 are is_near_equal to 0.0 and -3.0, respectively");

    // 1=0
    quadratic.a = 0, quadratic.b = 0, quadratic.c = 1;
    success = quadratic.solve();
    compare( success,
             false,
             "Roots of 1=0 do not have a solution, and are not computed");
    quadratic_solver_vals[6][0] = quadratic.root1, quadratic_solver_vals[6][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[6]),
                                       std::array<double, 2>{0.0, 0.0}),
             true,
             "Roots of 1=0 are both is_near_equal to 0.0");

    // 3x=0
    quadratic.a = 0, quadratic.b = 3, quadratic.c = 0;
    quadratic.solve();
    quadratic_solver_vals[7][0] = quadratic.root1, quadratic_solver_vals[7][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[7]),
                                       std::array<double, 2>{0.0, 0.0}),
             true,
             "Roots of 3x=0 are both is_near_equal to 0.0");

    // 3x^2=0
    quadratic.a = 3, quadratic.b = 0, quadratic.c = 0;
    quadratic.solve();
    quadratic_solver_vals[8][0] = quadratic.root1, quadratic_solver_vals[8][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[8]),
                                       std::array<double, 2>{0.0, 0.0}),
             true,
             "Roots of 3x^2=0 are both is_near_equal to 0.0");

    // 0=0
    quadratic.a = 0, quadratic.b = 0, quadratic.c = 0;
    success = quadratic.solve();
    compare( success,
             false,
             "Roots of 0=0 are infinite solutions, and are not computed");
    quadratic_solver_vals[9][0] = quadratic.root1, quadratic_solver_vals[9][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[9]),
                                       std::array<double, 2>{0.0, 0.0}),
             true,
             "Roots of 0=0 are both is_near_equal to 0.0");
    
    // x^2+(1e308)x+1=0
    quadratic.a = 1, quadratic.b = 1e308, quadratic.c = 1;
    quadratic.solve();
    quadratic_solver_vals[10][0] = quadratic.root1, quadratic_solver_vals[10][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[10]),
                                       std::array<double, 2>{-1e-308, -1e308}),
             true,
             "Roots of x^2+(1e308)x+1=0 are is_near_equal to -1e-308 and -1e308, respectively");

    // don't compute roots
    quadratic.a = 1, quadratic.b = -3, quadratic.c = 2;
    success = quadratic.solve(false);
    compare( success,
             true,
             "Roots 1 and 2 of x^2-3x+2=0 are defined, but are set to not be computed with compute_roots=false");
    quadratic_solver_vals[11][0] = quadratic.root1, quadratic_solver_vals[11][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[11]),
                                       std::array<double, 2>{0.0, 0.0}),
             true,
             "Roots 1 and 2 of x^2-3x+2=0 were not computed and are still both is_near_equal to 0.0");

    quadratic.a = 0, quadratic.b = 2, quadratic.c = 1;
    success = quadratic.solve(false);
    compare( success,
             true,
             "Roots 1 and 2 of 2x+1=0 are defined, but are set to not be computed with compute_roots=false");
    quadratic_solver_vals[12][0] = quadratic.root1, quadratic_solver_vals[12][1] = quadratic.root2;
    compare( MathUtils::is_near_equal( std_copy(quadratic_solver_vals[12]),
                                       std::array<double, 2>{0.0, 0.0}),
             true,
             "Roots 1 and 2 of 2x+1=0 were not computed and are still both is_near_equal to 0.0");

    check_comparison();
  }

private:
  /*****************************************************************************
  Purpose:(Used to compare the boolean output of each of the functions to the
           expected boolean output for a given input into the functions.)
  *****************************************************************************/
  void compare( bool input,
                bool expected,
                std::string test_name) {
    if (input != expected) {
      std::cout << "FAILURE: Expected output of " << expected << " but got "
      "output of " << input << " in test: " << test_name << std::endl;
      comparison_failure = true;
    }
    else {
      std::cout << "SUCCESS: Expected output of " << expected << " and got "
      "output of " << input << " in test: " << test_name << std::endl;
    }
  }

  void check_comparison() {
    if (comparison_failure) {
      CMLMessage::error(
        __FILE__,__LINE__,"Failed Comparison.\n",
        "One or more of tests just run have failed to successfully compare\n"
        "to the desired result. Check the comparison output above to find which\n"
        "comparison failed.");
    }
  }

  MathUtilsPrivateSimObject (const MathUtilsPrivateSimObject&);
  MathUtilsPrivateSimObject & operator = (const MathUtilsPrivateSimObject&);
