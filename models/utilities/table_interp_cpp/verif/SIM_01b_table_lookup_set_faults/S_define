#include "sim_objects/default_trick_sys.sm"
#include "jeod_sys.sm"

/*****************************************************************************
Test sim object
*****************************************************************************/
##include "../../include/table_lookup__transpose_data.hh"
##include "../../include/simple_table_lookup.hh"

class TestingModelSimObject : public Trick::SimObject {
 public:
  double dependent;
  double independent;
  double dependent_data[8];
  double independent_data[2];
  bool   use_small_line;
  bool   use_not_enabled;
  bool   use_extra_load;

  TableIndependentVariable  tiv_1;
  TableIndependentVariable  tiv_2;
  TableIndependentVariable  tiv_3;
  TableIndependentVariable  tiv_4;
  TableIndependentVariable  tiv_5;
  GenericMultiInputTable    generic_table;

  // Instance of TableLookupSet used to manage the 3 independent
  // variables and the single table that depends on them.
  TableLookupSet            manager;

  TestingModelSimObject()
    :
    use_small_line(false),
    use_not_enabled(false),
    use_extra_load(false),
    tiv_1(independent, TableIndependentVariable::Linear),
    tiv_2(independent, TableIndependentVariable::Linear),
    tiv_3(independent, TableIndependentVariable::Linear),
    tiv_4(independent),               // test this constructor
    tiv_5("has_a_name", independent), // test this constructor
    generic_table(),
    manager()
  {
    ("default_data")   data_config();
    (1.0, "scheduled") generic_table.update();
  }

  //***************************************************************************
  // data_config sets the baseline data values
  //***************************************************************************
  void data_config()
  {
    dependent_data[0] = 111;
    dependent_data[1] = 112;
    dependent_data[2] = 121;
    dependent_data[3] = 122;
    dependent_data[4] = 211;
    dependent_data[5] = 212;
    dependent_data[6] = 221;
    dependent_data[7] = 222;

    independent_data[0] = 1;
    independent_data[1] = 2;
  }

  //***************************************************************************
  // Provides good dependent data
  //***************************************************************************
  void load_dependent_data()
  {
    std::vector<size_t> dim_list(4,2); // i.e. 4 2's, {2,2,2,2}
    dim_list[0] = 1; // there is only 1 dependent. dim_list = {1,2,2,2}
    generic_table.add_dependent( dependent);
    generic_table.load_data(dependent_data, dim_list);
  }

  //***************************************************************************
  // Provides good independent data; adds tiv_1 to generic_table.
  //***************************************************************************
  void load_independent_data()
  {
    tiv_1.load_data( independent_data, 2);
    tiv_2.load_data( independent_data, 2);
    tiv_3.load_data( independent_data, 2);
    generic_table.add_independent( tiv_1);
  }



  //***************************************************************************
  // use the is_a_dependent_variable() function to show it works
  //***************************************************************************
  bool is_a_depend()
  {
    return manager.is_a_dependent_variable(dependent);
  }
  //***************************************************************************
  // Create two independents with identical names.
  //***************************************************************************
  void duplicate_name()
  {
    manager.create_independent_variable("Duplicate Name",independent);
    manager.create_independent_variable("Duplicate Name",independent);
  }
  //***************************************************************************
  // create a table with a NULL dependent variable.
  //***************************************************************************
  void create_table_with_NULL()
  {
    std::vector<double*> var(1,NULL);
    manager.create_table(var, AbstractTableLookup::Generic);
  }
  //***************************************************************************
  // create a table with duplicate dependents.
  //***************************************************************************
  void create_table_with_duplicate_dependent()
  {
    manager.create_table(2, &dependent, &dependent);
  }



  //***************************************************************************
  // Throw some invalid dependent data at generic_table.
  // This is handled in code because it deals a lot with STL-containers
  //***************************************************************************
  void populate_table_with_invalid_data_dependent()
  {
    std::vector<double> data_vec(dependent_data, dependent_data+8);

    // First, try loading data with a single value in dim_list.
    // This will error because the dim_list vector has to have at least
    //   2 entries.
    // Try this for both types of data - an array and a vector.
    std::vector<size_t> dim_list;
    dim_list.push_back(1);  // {1}
    std::cout << "***TEST: dim-list invalid, using array ***\n";
    generic_table.load_data(dependent_data, dim_list);
    std::cout << "***TEST: dim-list invalid, using vector ***\n";
    generic_table.load_data(data_vec, dim_list);

    // Make dim-list valid.
    dim_list.push_back(2); // {1,2}
    dim_list.push_back(2); // {1,2,2}
    dim_list.push_back(1); // {1,2,2,1}

    // This will still fail because the output has not been configured
    // There are no output variables but model is expecting 1
    std::cout << "***TEST: loading data before dependents assigned ***\n";
    generic_table.load_data(data_vec, dim_list);

    // What if I avoid this error by clearing the number of dependents?
    dim_list[0] = 0;
    std::cout << "***TEST: loading data without dependents using vector ***\n";
    generic_table.load_data(data_vec, dim_list);
    std::cout << "***TEST: loading data without dependents using array ***\n";
    generic_table.load_data(dependent_data, dim_list);

    // So add a dependent variable to match up with dim_list[0] = 1
    generic_table.add_dependent( dependent);
    dim_list[0] = 1;
    std::cout << "***TEST: loading data inconsistent with dim-list ***\n";
    generic_table.load_data(data_vec, dim_list);

    // Now make sure that the dim_list matches with the data vector
    dim_list[3] = 2;

    // Pass a NULL data array in:
    std::cout << "***TEST: sending a NULL data array ***\n";
    generic_table.load_data(NULL, dim_list);

    // This step will succeed
    generic_table.load_data(data_vec, dim_list);

    // But then try adding the data again.
    std::cout << "***TEST: loading data after it has been loaded ***\n";
    generic_table.load_data(data_vec, dim_list);
  }

  //***************************************************************************
  // Set pointer to indpendent var to null.
  //***************************************************************************
  void test_tiv_null()
  {
    tiv_1.load_data( NULL, 2 );
  }

  //***************************************************************************
  // load TIV with zero-length data
  //***************************************************************************
  void test_zero_length()
  {
    double data[3] = {1,2,3};
    tiv_2.load_data( data, 0 );
  }

  //***************************************************************************
  // load non-monotonic data
  //***************************************************************************
  void test_non_monotonic()
  {
    std::vector<double> non_mono_vec;
    non_mono_vec.push_back( 3.0 );
    non_mono_vec.push_back( 4.0 );
    non_mono_vec.push_back( 5.0 );
    non_mono_vec.push_back( 4.0 );
    non_mono_vec.push_back( 3.0 );
    tiv_3.load_data( non_mono_vec );
  }

  //***************************************************************************
  // load tiv data with duplicate data
  //***************************************************************************
  void test_duplicate_values()
  {
    std::vector<double> dup_vec;
    dup_vec.push_back( 3.0 );
    dup_vec.push_back( 4.0 );
    dup_vec.push_back( 5.0 );
    dup_vec.push_back( 5.0 );
    dup_vec.push_back( 5.0 );
    tiv_3.load_data( dup_vec );
  }

  //***************************************************************************
  // Assign inconsistent data (of the wrong size for the table) to the table's
  // TIV structure
  //***************************************************************************
  void populate_TIV_with_inconsistent_data()
  {
    double data[3] = {1,2,3};
    tiv_1.load_data(data,3);
  }
  //***************************************************************************
  // (try to) put the proper data into TIV so setup can continue.
  //***************************************************************************
  void reset_TIV_data()
  {
    double new_indep_data[2] = {1,2};
    tiv_1.load_data( new_indep_data, 2);
  }
  //***************************************************************************
  // Try to add more variables after initialization
  //***************************************************************************
  void add_table_vars_post_init()
  {
    std::cout << "***TEST: add dependent post-init ***\n";
    generic_table.add_dependent( dependent);
    std::cout << "***TEST: add independent post-init ***\n";
    generic_table.add_independent( tiv_1);
  }
  //***************************************************************************
  // Add valid - but trivial - independent data to generic_table.
  //***************************************************************************
  void populate_table_with_trivial_data()
  {
    double data = 1;
    tiv_1.load_data(&data,1);
    generic_table.add_independent( tiv_1);
    generic_table.add_dependent( dependent);

    std::vector<size_t> dim_list(2,1); // {1,1}
    generic_table.load_data(&data, dim_list);
  }
  //***************************************************************************
  // Try repopulating dependent-variables
  //***************************************************************************
  void reassign_output()
  {
    std::vector<double *> new_out(1,&dependent);
    generic_table.populate_output( new_out);
  }
  //***************************************************************************
  // Try repopulating dependent-variables with NULL
  //***************************************************************************
  void assign_output_to_empty()
  {
    std::vector<double *> new_out;
    generic_table.populate_output( new_out);
  }
  //***************************************************************************
  // Try repopulating dependent-variables with NULL
  //***************************************************************************
  void assign_output_to_null()
  {
    std::vector<double *> new_out(1,NULL);
    generic_table.populate_output( new_out);
  }

  //***************************************************************************
  // loads a NULL data in the table_independent_variable in two different ways
  // then loads a non monotonic vector into table_independent_variable
  //***************************************************************************
  void load_invalid_independent_data()
  {
    std::cout << "***TEST: Load NULL data into table_independent_variable ***\n";
    tiv_1.load_data(0,2);
    std::cout << "***TEST: Load Null data size into table_independent_variable ***\n";
    tiv_2.load_data(independent_data, 0);

    std::vector<double> indp_data(3);
    indp_data[0] = 1.5;
    indp_data[1] = 3.5;
    indp_data[2] = 2.5;
    std::cout << "***TEST: Load non-monotonic data into table_independent_variable ***\n";
    tiv_1.load_data(indp_data);
  }

 private:
   TestingModelSimObject( const TestingModelSimObject&);
   TestingModelSimObject& operator = ( const TestingModelSimObject&);
};

TestingModelSimObject test;
