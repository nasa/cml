//trick
#include "sim_objects/default_trick_sys.sm"

//jeod
#include "jeod_sys.sm"

//test model
##include "include/test_model_interp2d.hh"


class TestTblInterp2D_SimObj : public Trick::SimObject
{
public:
  const double base;  /* (--) the starting point of independent variable. */
  const double step;  /* (--) the interval of independent variable between two simulation steps. */

  double var_x;       /* (--) the independent variable X */
  double var_y;       /* (--) the independent variable Y */
  double interp_val;  /* (--) the interpolated value */
  int low_index_x;    /* (--) the lower breakpoint index of X */
  double frac_x;      /* (--) the fractional distance in the interval between breakpoints of X */
  int low_index_y;    /* (--) the lower breakpoint index of Y */
  double frac_y;      /* (--) the fractional distance in the interval between breakpoints of Y */

  bool is_asc;        /* (--) indicate whether the variable data is ascending or desending */

  TestModelInterp2D<20, 10> test_model;
  
  TestTblInterp2D_SimObj() :
    base(-3.0),
    step(0.25),
    is_asc(true),
    test_model(base, 2.0*step)
  {
    ("initialization") init();
    (1.0, "scheduled") update();
  };

private:
  TestTblInterp2D_SimObj(const TestTblInterp2D_SimObj&);
  TestTblInterp2D_SimObj& operator=(const TestTblInterp2D_SimObj&);

  void init()
  {
    test_model.set_default_data(is_asc);
  }

  void update()
  {
    const double step_impl = is_asc ? step : -step;

    static double prev_x= base-step_impl;
    static double prev_y = base-step_impl;
    var_x = prev_x + step_impl;  
    var_y = prev_y + step_impl;  
    interp_val = test_model.update(var_x, var_y);
    prev_x = var_x;
    prev_y = var_y;
   
    low_index_x = test_model.get_low_index_x();
    frac_x = test_model.get_frac_x();
    low_index_y = test_model.get_low_index_y();
    frac_y = test_model.get_frac_y();
  }
};

TestTblInterp2D_SimObj test_interp2d;

