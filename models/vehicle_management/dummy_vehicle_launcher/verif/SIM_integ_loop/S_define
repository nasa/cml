class VerifSimObject : public Trick::SimObject {
    public:
        DummyVehicleLauncher           launcher; // (--) makes the vehicle active
        DummyVehicleLauncher           launcher_no_mass_body;
        jeod::MassBody                 mass_body;
        jeod::DynamicsIntegrationGroup group;
        er7_utils::RK4IntegratorConstructor   rk4_constructor;
        er7_utils::IntegratorConstructor * rk4_constructor_ptr;

        VerifSimObject(VehicleBasicSimObject & vehicle_in,
                       VehicleSimObject & vehicle2_in)
            :
            launcher(vehicle2_in.dyn_body, // populate this body
                     mass_body,            //   with these mass data
                     vehicle_in.dyn_body), //   and these state data
            launcher_no_mass_body(vehicle2_in.dyn_body,
                                  vehicle_in.dyn_body),
            rk4_constructor_ptr(&rk4_constructor)
        {
            ("initialization") launcher.initialize_integ_group_actions();
            ("initialization") launcher_no_mass_body.initialize_integ_group_actions();
        };
    
    private:
        VerifSimObject (const VerifSimObject&);
        VerifSimObject & operator = (const VerifSimObject&);
};
VerifSimObject dummy_veh_launcher_verif(vehicle, 
                                        vehicle2);

